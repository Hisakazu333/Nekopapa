{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NekoPapa",
  "version": "0.2.0",
  "identifier": "ai.nekopapa.desktop",
  "build": {
    "beforeDevCommand": "npm run stage:prepare && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run stage:prepare && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "NekoPapa",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/openneko-live2d-stage"],
    "resources": {
      "../../../assets/live2d": "assets/live2d"
    }
  }
}
